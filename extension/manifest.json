{
  "manifest_version": 3,
  "name": "IntraView – LeetCode Voice Recorder",
  "version": "1.0.0",
  "description": "Record your voice while solving LeetCode problems.",
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": [
    "https://leetcode.com/*",
    "http://localhost:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
